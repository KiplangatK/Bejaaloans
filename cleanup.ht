<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Clear Loans | Bejja Credit</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body style="background:#edf4ff; font-family:'Segoe UI',sans-serif;">

<div class="container py-5">
    <div class="card shadow-lg mx-auto" style="max-width:600px; border-radius:20px;">
        <div class="card-body p-5 text-center">
            
            <i class="fa-solid fa-broom fa-3x text-warning mb-3"></i>
            <h3>Clear All Loans</h3>
            <p class="text-muted">Deletes all active/late loans and applications.</p>
            <p class="text-success"><b>Clients and admin will NOT be deleted.</b></p>
            
            <div id="status" class="alert alert-info mt-3">Ready.</div>
            
            <button id="clearBtn" class="btn btn-warning btn-lg w-100" onclick="clearLoans()">
                <i class="fa fa-trash"></i> Clear All Loans & Applications
            </button>
            
            <a href="admin-dashboard.html" class="btn btn-primary w-100 mt-3">
                <i class="fa fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>
</div>

<script src="assets/js/database.js"></script>
<script>
async function clearLoans() {
    if (!confirm("Delete all loans and applications? Clients will be kept.")) return;
    
    document.getElementById("clearBtn").disabled = true;
    document.getElementById("clearBtn").innerHTML = '<i class="fa fa-spinner fa-spin"></i> Deleting...';
    
    try {
        let loans = await DB.getLoans();
        for (let loan of loans) {
            await DB.deleteLoan(loan.id);
        }
        
        let applications = await DB.getApplications();
        for (let app of applications) {
            await DB.deleteApplication(app.id);
        }
        
        document.getElementById("status").className = "alert alert-success";
        document.getElementById("status").innerHTML = `
            <h5>✅ Done!</h5>
            <p>Deleted ${loans.length} loans and ${applications.length} applications.</p>
            <p>Clients are safe. Refresh your pages.</p>
        `;
        
    } catch(e) {
        document.getElementById("status").className = "alert alert-danger";
        document.getElementById("status").innerHTML = "Error: " + e.message;
    }
}
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</body>
</html>
